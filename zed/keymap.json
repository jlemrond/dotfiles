[
  {
    "bindings": {
      // put key-bindings here if you want them to work in normal & visual mode
      "cmd-escape": "menu::Cancel"
    }
  },
  {
    // put key-bindings here if you want them to work only in normal mode
    "context": "Editor && vim_mode == normal && !VimWaiting && !menu",
    "bindings": {
      "space t p": ["task::Spawn", { "task_name": "go test package" }],
      "ctrl-h": "project_panel::ToggleFocus"
    }
  },
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "o": "project_panel::Open",
      "ctrl-l": "project_panel::ToggleFocus"
    }
  },
  {
    "context": "VimControl",
    "bindings": {
      "-": "pane::RevealInProjectPanel"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "cmd-e": "pane::RevealInProjectPanel",
      "cmd-l": "workspace::CloseAllDocks",
      "cmd-.": "workspace::CloseAllDocks"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-e": "pane::RevealInProjectPanel",
      "cmd-g": "git_panel::ToggleFocus",
      "cmd-l": "workspace::CloseAllDocks",
      "cmd-.": "workspace::CloseAllDocks"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-e": "pane::RevealInProjectPanel",
      "cmd-l": "workspace::CloseAllDocks",
      "cmd-.": "workspace::CloseAllDocks"
    }
  },
  {
    "context": "Editor && (vim_mode == normal || vim_mode == visual) && !VimWaiting && !menu",
    "bindings": {
      "space 1": ["pane::ActivateItem", 0],
      "space 2": ["pane::ActivateItem", 1],
      "space 3": ["pane::ActivateItem", 2],
      "space 4": ["pane::ActivateItem", 3],
      "space 5": ["pane::ActivateItem", 4],
      "space 6": ["pane::ActivateItem", 5],
      "space 7": ["pane::ActivateItem", 6],
      "space 8": ["pane::ActivateItem", 7]
    }
  }
]
